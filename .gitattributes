# Normalize line endings across macOS / Windows / Linux.
# All text is stored as LF in the repo; Git checks it out natively per OS.
* text=auto eol=lf

# Explicit text types (so diffs/merges treat them as text everywhere).
*.dart    text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.gradle  text eol=lf
*.kts     text eol=lf
*.kt      text eol=lf
*.java    text eol=lf
*.swift   text eol=lf
*.h       text eol=lf
*.m       text eol=lf
*.cpp     text eol=lf
*.xml     text eol=lf
*.plist   text eol=lf
*.html    text eol=lf
*.css     text eol=lf
*.js      text eol=lf
*.sql     text eol=lf
*.toml    text eol=lf
*.txt     text eol=lf
*.rc      text eol=lf
*.cmake   text eol=lf
*.properties text eol=lf
.gitignore   text eol=lf
.gitattributes text eol=lf

# Windows-only tooling must keep CRLF or it breaks.
*.bat     text eol=crlf
*.cmd     text eol=crlf
*.ps1     text eol=crlf

# Binary assets — never touch line endings or try to diff them.
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.webp    binary
*.svg     binary
*.ttf     binary
*.otf     binary
*.woff    binary
*.woff2   binary
*.tflite  binary
*.keystore binary
*.jks     binary
*.so      binary
*.jar     binary
*.zip     binary
*.apk     binary
*.aab     binary
